{
  "meta": {
    "name": "KOBLLUX Trinity Engine",
    "version": "3.0.0",
    "cycle": "001 · 3→6→9→7",
    "frequency": "1134Hz",
    "description": "Schema de identidade, tema, arquétipos e sincronização de estado para o ecossistema KOBLLUX"
  },

  "cssVariables": {
    "root": {
      "description": "CSS Custom Properties base (em :root)",
      "timing": {
        "--kob-dur": "1.28s",
        "--kob-ease": "cubic-bezier(.2,.7,.2,1)",
        "description": "Duração e função de easing para transições globais"
      },
      "colors": {
        "--bg-dark": "#05070a",
        "--ink": "#f0f3f9",
        "--text": "#f0f3f9",
        "--text-muted": "#9aa4c8",
        "--muted": "rgba(255, 255, 255, 0.45)",
        "--kob-voice-primary": "#78e3ff",
        "--kob-voice-secondary": "#b978ff",
        "--kob-voice-accent": "#ffffff",
        "description": "Paleta base (pode ser sobrescrita por arquétipo)"
      },
      "panels": {
        "--panel-bg": "rgba(8, 10, 18, 0.72)",
        "--panel-blur": "blur(18px) saturate(160%)",
        "--border": "rgba(120, 227, 255, 0.18)",
        "--border-active": "rgba(120, 227, 255, 0.55)",
        "description": "Estilo de painéis glassmorphism"
      },
      "archetype": {
        "--arch-color": "var(--kob-voice-primary)",
        "--arch-glow": "color-mix(in srgb, var(--arch-color) 28%, transparent)",
        "--grad-a": "var(--kob-voice-primary)",
        "--grad-b": "var(--kob-voice-secondary)",
        "description": "Dinâmicas de cor e brilho por arquétipo"
      },
      "layout": {
        "--z-base": 0,
        "--z-content": 100,
        "--z-widget": 500,
        "--z-overlay": 1000,
        "--z-system": 5000,
        "description": "Stacking context (z-index) para camadas"
      }
    }
  },

