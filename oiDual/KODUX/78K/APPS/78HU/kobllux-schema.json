    "schema": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Identificador único (lowercase)"
        },
        "name": {
          "type": "string",
          "description": "Nome exibido do arquétipo"
        },
        "primary": {
          "type": "string",
          "pattern": "^#[0-9A-F]{6}$",
          "description": "Cor primária (hex)"
        },
        "secondary": {
          "type": "string",
          "pattern": "^#[0-9A-F]{6}$",
          "description": "Cor secundária (hex)"
        },
        "tone": {
          "enum": ["warm", "cool", "neutral"],
          "description": "Temperatura da cor"
        },
        "pitch": {
          "type": "number",
          "minimum": 0.5,
          "maximum": 2.0,
          "description": "Pitch para speech synthesis (0.5-2.0)"
        },
        "rate": {
          "type": "number",
          "minimum": 0.5,
          "maximum": 2.0,
          "description": "Rate para speech synthesis (velocidade)"
        },
        "role": {
          "type": "string",
          "description": "Papel semântico do arquétipo"
        }
      },
      "required": ["id", "name", "primary", "secondary", "tone", "pitch", "rate", "role"]
    }
  },

  "dataAttributes": {
    "description": "Atributos HTML para controle sem classes",
    "role": {
      "name": "data-k-role",
      "values": [
        "orb",
        "drawer",
        "vault",
        "frame",
        "panel",
        "button",
        "player",
        "runtime",
        "card",
        "symbol-bar"
      ],
      "example": "<div data-k-role='orb'></div>"
    },
    "layer": {
      "name": "data-k-layer",
      "values": [
        "background",
        "content",
        "widget",
        "overlay",
        "system"
      ],
      "cssMapping": {
        "background": "z-index: var(--z-base)",
        "content": "z-index: var(--z-content)",
        "widget": "z-index: var(--z-widget)",
        "overlay": "z-index: var(--z-overlay)",
        "system": "z-index: var(--z-system)"
      },
      "example": "<div data-k-layer='content'></div>"
    },
    "voiceArch": {
      "name": "data-voice-arch",
      "values": "qualquer id de arquétipo (atlas, nova, vitalis, etc)",
      "example": "<body data-voice-arch='dual'>",
      "cssInjection": "body[data-voice-arch='dual'] { --kob-voice-primary: #06B6D4; --kob-voice-secondary: #0E7C9E; }"
    },
    "tone": {
      "name": "data-tone",
      "values": ["warm", "cool"],
      "example": "<div class='orb' data-tone='cool'></div>"
    },
    "state": {
      "name": "data-state",
      "values": [
        "idle",
        "active",
        "speaking",
        "loading",
        "error",
        "fused"
      ],
      "example": "<div data-k-role='orb' data-state='speaking'></div>"
    }
  },

  "cssLayers": {
    "description": "Estrutura de injeção de estilos (em ordem de precedência)",
    "1_transitions": {
      "name": "KOB_THEME_TRANSITION_SOFT_CSS",
      "frequency": "285Hz",
      "content": "Transições globais (background, color, border-color, shadow, opacity, transform)",
      "easing": "cubic-bezier(.2,.7,.2,1)",
      "duration": "1.28s"
    },
    "2_background": {
      "name": "KOB_BG_FADE_CSS",
      "frequency": "432Hz",
      "content": "Fundo radial (magenta + cyan), grade fractal com mask radial"
    },
    "3_buttons": {
      "name": "KOB_BUTTON_FADE_AND_TTS_SHADOW_CSS",
      "frequency": "528Hz",
      "content": "Botões com cyan border, hover magenta glow, animação de pulso TTS"
    },
    "4_archetype": {
      "name": "KOB_VOICE_THEME_CSS_PATCH",
      "content": "Data-voice-arch → --arch e --glow, .archMsg com border-left e text-shadow"
    },
    "5_presence": {
      "name": "KOBLLUX_VOICE_THEME_CSS",
      "frequency": "1134Hz",
      "content": "Padding, border-radius, font (JetBrains Mono), .arch-speak-btn.active"
    }
  },

  "architecture": {
    "layers": [
      {
        "level": 1,
        "name": "Hardware",
        "description": "CPU, GPU, sensores (touch, motion, mic, camera)"
      },
      {
        "level": 2,
        "name": "Kernel",
        "description": "Sistema operacional (iOS, Android, Linux, macOS, Windows)"
      },
      {
        "level": 3,
        "name": "Runtime",
        "description": "Browser (Chrome, Safari, Firefox) ou aplicação nativa"
      },
      {
        "level": 4,
        "name": "KOBLLUX Core",
        "description": "Núcleo do ecossistema (identidade, tema, voz)"
      },
      {
        "level": 5,
        "name": "MetaBus",
        "description": "Barramento de eventos e comunicação entre módulos"
      },
      {
        "level": 6,
        "name": "KPM",
        "description": "Package Manager (organização e carregamento de módulos)"
      },
      {
        "level": 7,
        "name": "Arquétipos",
        "description": "Perfis de identidade com voz, cor, comportamento"
      },
      {
        "level": 8,
        "name": "Aplicação",
        "description": "UI final (HUB UNO, Infodose, DualBook, ORB78, etc)"
      }
    ]
  },

  "metaBus": {
    "description": "Sistema de eventos pub/sub para sincronização entre componentes",
    "events": [
      {
        "name": "touch:start",
        "payload": { "x": "number", "y": "number", "target": "element" },
        "description": "Toque iniciado na tela"
      },
      {
        "name": "touch:end",
        "payload": { "duration": "number" },
        "description": "Toque finalizado"
      },
      {
        "name": "theme:changed",
        "payload": { "arch": "string", "primary": "string", "secondary": "string" },
        "description": "Tema/arquétipo foi alterado"
      },
      {
        "name": "voice:recognized",
        "payload": { "text": "string", "arch": "string" },
        "description": "Voz reconhecida/processada"
      },
      {
        "name": "atlas:loaded",
        "payload": { "version": "string" },
        "description": "Engine de voz (Atlas) carregado"
      },
      {
        "name": "emotion:happy",
        "payload": { "intensity": "number 0-1" },
        "description": "Emoção positiva detectada"
      },
      {
        "name": "particle:spawn",
        "payload": { "x": "number", "y": "number", "amount": "number" },
        "description": "Partículas spawned no campo"
      },
      {
        "name": "di:name:update",
        "payload": { "name": "string" },
        "description": "Nome de usuário atualizado"
      },
      {
        "name": "di:storage:sync",
        "payload": { "key": "string", "value": "any" },
        "description": "localStorage sincronizado entre abas"
      },
      {
        "name": "orb:fused",
        "payload": { "arch": "string" },
        "description": "Orb fundido com Symbol Bar"
      }
    ]
  },

  "stateModel": {
    "description": "Estrutura de estado principal (localStorage + window.DI)",
    "storage": {
      "di_userName": "string (nome do usuário)",
      "di_arch": "string (arquétipo primário)",
      "di_dualArch": "string (arquétipo secundário/dual)",
      "di_mode": "string (data-classic, voice-mode, etc)",
      "di_voiceTheme": "string (nome do tema de voz)",
      "kobllux_engine_step": "number (posição no Motor 369)",
      "kobllux_jump": "boolean (modo jump ativo)",
      "kobllux_reverse": "boolean (modo reverse ativo)",
      "DI_369_cycle": "number (ciclo 3-6-9-7)"
    },
    "runtime": {
      "window.DI": {
        "STATE": {
          "name": "string",
          "seed": "number",
          "h1": "number (0-360, hue 1)",
          "h2": "number (0-360, hue 2)",
          "tone": "string (warm|cool)"
        },
        "applyRootVars": "function(name) → aplica CSS vars",
        "makeOrbAvatar": "function(name, size) → SVG",
        "syncNameUI": "function(name) → atualiza DOM + localStorage"
      }
    }
  },

  "flowDiagram": {
    "description": "Fluxo típico de inicialização e uso",
    "steps": [
      "1. Usuário digita nome ou carrega localStorage",
      "2. di_syncNameUI(name) chamada",
      "3. di_seed(name) gera número a partir de caracteres",
      "4. h1 = seed % 360, h2 = (seed * 37) % 360",
      "5. tone = h1 > 180 ? 'warm' : 'cool'",
      "6. di_applyRootVars() injeta --di-h1, --di-h2, --di-accent, etc em :root",
      "7. body[data-voice-arch] atualizado",
      "8. CSS vars reagem → cores e glows propagam",
      "9. di_makeOrbAvatar() gera SVG com gradiente dinâmico",
      "10. Avatares em #main-orb, #avatarTarget, etc atualizados",
      "11. MetaBus emite 'theme:changed' para componentes ouvirem"
    ]
  },

  "bridgeController": {
    "description": "Sincronização bidirecional entre Orb Canvas e Campo de Partículas",
    "orbState": {
      "pulse": "number (0-1)",
      "energy": "number (0-1)",
      "active": "boolean"
    },
    "fieldState": {
      "density": "number (quantidade de partículas)",
      "velocity": "number (velocidade média)",
      "centroidX": "number (x do centróide)",
      "centroidY": "number (y do centróide)"
    },
    "feedback": {
      "orbToField": "clique no orb → spawn de partículas, aumenta attractor strength",
      "fieldToOrb": "velocidade do campo → glow dinâmico no orb"
    }
  },

  "kpm": {
    "description": "KOBLLUX Package Manager: registro de módulos reutilizáveis",
    "modules": [
      {
        "name": "core/kernel.js",
        "exports": ["di_seed", "di_applyRootVars", "di_makeOrbAvatar"],
        "dependencies": []
      },
      {
        "name": "ui/particles/index.js",
        "exports": ["KOBParticles"],
        "dependencies": []
      },
      {
        "name": "ui/themes/index.js",
        "exports": ["ARCH_PRESETS", "ARCH_NAMES", "ARCH_COLORS"],
        "dependencies": []
      },
      {
        "name": "audio/voice/index.js",
        "exports": ["speakWithCurrentArchetype", "setVoiceArchetype"],
        "dependencies": ["core/kernel"]
      },
      {
        "name": "bridge/controller.js",
        "exports": ["KOBBridgeController"],
        "dependencies": ["ui/particles/index.js"]
      },
      {
        "name": "storage/index.js",
        "exports": ["syncLocalStorage", "loadState"],
        "dependencies": []
      }
    ]
  },

  "cssInjectPipeline": {
    "description": "Sequência de injeção de CSS para garantir precedência correta",
    "order": [
      "1. KOB_THEME_TRANSITION_SOFT_CSS (transições base)",
      "2. KOB_BG_FADE_CSS (fundo + grid)",
      "3. KOB_BUTTON_FADE_AND_TTS_SHADOW_CSS (botões + TTS pulse)",
      "4. KOB_VOICE_THEME_CSS_PATCH (data-voice-arch → cores)",
      "5. KOBLLUX_VOICE_THEME_CSS (presença + sotaque)"
    ],
    "idempotency": "Verifica if(document.getElementById(ID)) return antes de injetar",
    "console": "Logs em %c com estilos (color, background, padding, border, font-weight)"
  },

  "performance": {
    "notes": [
      "Evitar * { transition: ... } em mobile → usar seletores específicos",
      "CSS Layers (@layer) para melhor controle de override",
      "Namespace window.KOBLLUX em vez de window.KOB_* (menos poluição global)",
      "Canvas (orb + particles) renderiza diretamente → sem layout thrashing",
      "requestAnimationFrame para sincronização de refresh"
    ]
  },

  "exportNotes": {
    "schema": "Este objeto descreve a identidade, estrutura e sincronização do KOBLLUX em formato estruturado",
    "usage": "Use para documentação, integração em novos módulos, ou validação em tempo de execução",
    "versionControl": "Atualizar version quando houver mudanças em arquétipos ou estrutura de dados"
  }
}
